def _cache_root():
    base = os.environ.get("XDG_CACHE_HOME")
    return Path(base) if base else Path.home() / ".cache"


def cache_path():
    return _cache_root() / "toks" / "tokens-per-second.json"


def legacy_cache_path():
    return _cache_root() / "ollama-list-with-tps" / "tokens-per-second.json"


def load_cache():
    path = cache_path()
    source = path if path.exists() else legacy_cache_path()
    if not source.exists():
        return {}
    try:
        with source.open("r", encoding="utf-8") as handle:
            data = json.load(handle)
    except (OSError, json.JSONDecodeError):
        return {}
    if not isinstance(data, dict):
        return {}
    return migrate_cache(data)


def save_cache(cache):
    path = cache_path()
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("w", encoding="utf-8") as handle:
        json.dump(cache, handle, indent=2, sort_keys=True)
        handle.write("\n")


# --- orchestration ----------------------------------------------------------


def select_bench_records(records, targets, cache):
    """Resolve --bench targets to the records to benchmark.

    Empty targets or ["missing"] selects records without a cached tokens/sec
    value; ["all"] selects everything; anything else is a list of model names.
    Returns (selected_records, unknown_names).
    """
    if not targets or targets == ["missing"]:
        return [r for r in records if cached_tps(cache, r) is None], []
    if targets == ["all"]:
        return list(records), []
    requested = set(targets)
    selected = [r for r in records if r.name in requested]
    unknown = sorted(requested - {r.name for r in selected})
    return selected, unknown


def nonce_prompt(prompt):
    """Prefix a prompt with random bytes so no two timed runs share a KV prefix.

    A leading nonce (not a suffix) is deliberate: llama.cpp's prefix cache keys on
    the leading tokens, so a unique lead forces cache_n==0 and stops ngram-mod from
    replaying a prior identical generation. The ~3-token nonce is negligible vs 256.
    """
    return f"[{secrets.token_hex(3)}] {prompt}"


def aggregate_samples(results):
    """Reduce N independent BenchResults to the cached median + spread.

    Throughput is the median of the per-run rates (tps_min/tps_max record the
    spread); TTFT the median of the runs that reported one. Speculative-decode
    acceptance is *pooled* (Sigma accepted / Sigma drafted, surfaced as the two
    counters) -- the statistically correct aggregate, not a mean of per-run ratios.
    """
    tps = [r.tokens_per_second for r in results]
    ttfts = [r.time_to_first_token for r in results
             if r.time_to_first_token is not None]
    drafted = sum(r.draft_n or 0 for r in results)
    accepted = sum(r.draft_n_accepted or 0 for r in results)
    return {
        "tokens_per_second": statistics.median(tps),
        "tps_min": min(tps),
        "tps_max": max(tps),
        "samples": len(tps),
        "time_to_first_token": statistics.median(ttfts) if ttfts else None,
        "draft_n": drafted or None,
        "draft_n_accepted": accepted if drafted else None,
    }


def _bench_samples(provider, rec, base_prompt, samples):
    """Run `samples` nonced benchmarks of one prompt kind; return the BenchResults.

    Each run carries a fresh nonce so no two timed prompts share a KV prefix (a
    single sample varies 20-30%, and a cached/speculated backend far more). A
    sample whose cache_n exceeds the prefix budget is flagged -- the nonce failed
    or an external cache replayed the prompt -- but still kept; the warning, not
    suppression, is the contract. Stops at the first failed or empty sample.
    """
    results = []
    for _ in range(samples):
        try:
            result = provider.benchmark(rec, nonce_prompt(base_prompt),
                                        DEFAULT_MAX_TOKENS)
        except RuntimeError as exc:
            print(f"warning: benchmark failed for {rec.name}: {exc}", file=sys.stderr)
            break
        if result is None:
            print(f"warning: no throughput stats returned for {rec.name}", file=sys.stderr)
            break
        results.append(result)
        if result.cache_n is not None and result.cache_n > CACHE_N_BUDGET:
            print(f"warning: {rec.name}: timed sample served cache_n="
                  f"{result.cache_n} tokens from the prefix cache; throughput "
                  "may be inflated", file=sys.stderr)
    return results


def run_benchmarks(records, active, cache, samples=DEFAULT_SAMPLES, kinds=None):
    """Benchmark the given records in place; return True if the cache changed.

    Each record is measured over the prompt `kinds` (default prose only; the suite
    adds code), with `samples` nonced runs per kind aggregated to a median + spread.
    The cached top-level throughput tracks the primary (prose) kind so legacy
    readers are unaffected; a multi-kind run also nests every kind under `by_kind`.
    """
    kinds = kinds or ["prose"]
    primary = kinds[0]
    changed = False
    for rec in records:
        if not rec.benchmarkable:
            print(f"skipping {rec.name}: unsupported model type/format", file=sys.stderr)
            continue
        provider = active.get(rec.provider)
        if provider is None:
            continue
        print(f"benchmarking {rec.provider}/{rec.name}...", file=sys.stderr)
        measured = {}       # kind -> (aggregate dict, representative BenchResult)
        for kind in kinds:
            results = _bench_samples(provider, rec, BENCH_PROMPTS[kind], samples)
            if results:
                measured[kind] = (aggregate_samples(results), results[0])
        if primary not in measured:
            continue        # no trustworthy number for the headline kind
        agg, rep = measured[primary]
        host = getattr(provider, "host", None)
        expected = getattr(provider, "expected_backend", None)
        observed = rep.observed_backend
        # The cached number is only trustworthy if we know who served it. The
        # 'provider' field is just the configured label for whatever answered at
        # this URL; record the *observed* engine, and shout if it isn't the one
        # this port is supposed to host (e.g. a llama.cpp server squatting on the
        # mlx port) so a mislabeled number can't poison cross-runtime comparisons.
        if expected and observed and observed not in ("unknown", expected):
            print(f"warning: {rec.name}: expected {expected} at {host} but "
                  f"observed {observed} (fingerprint={rep.system_fingerprint}); "
                  "recording the observed backend", file=sys.stderr)
        entry = {
            "provider": rec.provider,
            "model": rec.name,
            "tokens_per_second": agg["tokens_per_second"],
            "tps_min": agg["tps_min"],
            "tps_max": agg["tps_max"],
            "samples": agg["samples"],
            "time_to_first_token": agg["time_to_first_token"],
            "draft_n": agg["draft_n"],
            "draft_n_accepted": agg["draft_n_accepted"],
            "endpoint": host,
            "tps_source": rep.tps_source,
            "observed_backend": observed,
            "system_fingerprint": rep.system_fingerprint,
            "benchmarked_at": int(time.time()),
            "prompt": BENCH_PROMPTS[primary],
            "prompt_nonced": True,
            "max_tokens": DEFAULT_MAX_TOKENS,
        }
        if len(kinds) > 1:
            entry["by_kind"] = {kind: dict(kagg)
                                for kind, (kagg, _) in measured.items()}
        cache[cache_key(rec)] = entry
        changed = True
    return changed


def parse_args(argv=None):
    parser = argparse.ArgumentParser(
        description="List local models (Ollama + LM Studio + mlx-lm + Unsloth Studio "
                    "+ llama.cpp server) with cached tokens/sec and bits/weight columns."
    )
    parser.add_argument(
        "--provider",
        choices=("ollama", "lmstudio", "mlx", "unsloth", "llama", "all"),
        default="all",
        help="which backend(s) to query (default: all reachable)",
    )
    parser.add_argument(
        "--bench",
        nargs="*",
        metavar="TARGET",
        default=None,
        help="benchmark before printing the table: no value or 'missing' "
             "benchmarks models without a cached value, 'all' benchmarks "
             "every model, anything else names the model(s) to benchmark",
    )
    parser.add_argument(
        "--samples",
        type=int,
        default=DEFAULT_SAMPLES,
        metavar="N",
        help=f"independent (nonced) runs to take the median over "
             f"(default {DEFAULT_SAMPLES})",
    )
    parser.add_argument(
        "--bench-suite",
        action="store_true",
        help="benchmark a {prose, code} prompt pair instead of prose only; "
             "adds nested by_kind results and CODE/S + CODE%% columns",
    )
    args = parser.parse_args(argv)
    if args.samples < 1:
        parser.error("--samples must be at least 1")
    targets = args.bench or []
    if len(targets) > 1 and not {"all", "missing"}.isdisjoint(targets):
        parser.error("--bench: 'all'/'missing' cannot be combined with other targets")
    return args


def main():
    args = parse_args()
    load_dotenv()   # read-only: ~/.config/toks/.env, real env vars win

    records, active, statuses = gather_records(select_providers(args.provider))
    if statuses:
        use_color = sys.stderr.isatty() and not os.environ.get("NO_COLOR")
        print(provider_status_line(statuses, color=use_color), file=sys.stderr)
    if not active:
        raise RuntimeError("no model providers reachable")

    cache = load_cache()
    display = records
    if args.bench is not None:
        selected, unknown = select_bench_records(records, args.bench, cache)
        if unknown:
            print(f"warning: model not found: {', '.join(unknown)}", file=sys.stderr)
        kinds = ["prose", "code"] if args.bench_suite else ["prose"]
        if run_benchmarks(selected, active, cache, samples=args.samples,
                          kinds=kinds):
            save_cache(cache)
        # With --bench, print only the targeted models, not the whole listing.
        display = selected

    display.sort(key=lambda r: tps_sort_key(cache, r))
    table_color = sys.stdout.isatty() and not os.environ.get("NO_COLOR")
    print(table(build_rows(display, cache, color=table_color)))


if __name__ == "__main__":
    try:
        main()
    except RuntimeError as exc:
        print(f"error: {exc}", file=sys.stderr)
        sys.exit(1)

