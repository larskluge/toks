def gather_records(providers):
    """List models from every reachable provider; isolate per-provider failures.

    Returns (records, active, statuses) where statuses is a list of
    (provider_name, reachable) pairs in query order, for a one-line summary.
    """
    records = []
    active = {}
    statuses = []
    for provider in providers:
        try:
            recs = provider.list_models()
        except RuntimeError:
            statuses.append((provider.name, False))
            continue
        records.extend(recs)
        active[provider.name] = provider
        statuses.append((provider.name, True))
    return records, active, statuses


