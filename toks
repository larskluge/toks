def normalize_host(value, default):
    host = (value or default).strip().rstrip("/")
    if not host.startswith(("http://", "https://")):
        host = "http://" + host
    return host


# --- normalized model record ------------------------------------------------


@dataclass
class ModelRecord:
    provider: str                       # "ollama" | "lmstudio" | "mlx"
    name: str                           # display id (Ollama tag / LM Studio id)
    fmt: str = ""                       # gguf | safetensors | mlx | ""
    params: str = "-"                   # display string, e.g. "8B" or "-"
    moe: bool = False
    quant: str = "-"
    size_bytes: float | None = None     # on-disk size, None if unknown
    modified_at: str | None = None      # ISO timestamp, None for LM Studio
    ctx_max: int | None = None
    ctx_loaded: int | None = None
    benchmarkable: bool = False
    loaded: bool = False                 # True when resident/serving, not just on disk
    digest: str | None = None           # stable id for cache key (Ollama digest)
    param_count: int | None = None      # numeric total params (real or estimated)
    param_estimated: bool = False       # True when param_count derived from size
    raw: dict = field(default_factory=dict)


@dataclass
class BenchResult:
    tokens_per_second: float
    time_to_first_token: float | None = None
    tps_source: str | None = None        # measurement path: ollama|lmstudio_stats|
                                         # llamacpp_timings|client_timed
    observed_backend: str | None = None  # engine inferred from the response:
                                         # ollama|lmstudio|llamacpp|mlx_lm|unknown
    system_fingerprint: str | None = None
    draft_n: int | None = None           # speculative tokens proposed (MTP/ngram)
    draft_n_accepted: int | None = None  # of those, verified/kept
    cache_n: int | None = None           # tokens served from the KV prefix cache


def _looks_llamacpp_fingerprint(fingerprint):
    """True for a llama.cpp build fingerprint like 'b9773-<hash>'."""
    head = str(fingerprint or "").split("-", 1)[0]
    return len(head) > 1 and head[0] == "b" and head[1:].isdigit()


def _classify_streamed_backend(fingerprint, saw_timings, otherwise):
    """Infer the engine behind an OpenAI-style stream from its tells.

    A llama.cpp `timings` block or a `b<build>-…` fingerprint is conclusive;
    otherwise fall back to the caller's expected engine (the mlx provider knows a
    plain stream is mlx_lm; Studio, being multi-runtime, settles for 'unknown').
    """
    if saw_timings or _looks_llamacpp_fingerprint(fingerprint):
        return "llamacpp"
    return otherwise


def _looks_moe(*texts):
    return any("moe" in (t or "").lower() for t in texts)


# --- LM Studio provider parsing ---------------------------------------------


def lmstudio_parse_models(payload):
    """Parse a GET /api/v0/models response into ModelRecords."""
    data = (payload or {}).get("data")
    if not isinstance(data, list):
        return []
    records = []
    for item in data:
        if not isinstance(item, dict):
            continue
        model_id = item.get("id")
        if not model_id:
            continue
        model_type = (item.get("type") or "").lower()
        fmt = (item.get("compatibility_type") or "").lower()
        records.append(
            ModelRecord(
                provider="lmstudio",
                name=model_id,
                fmt=fmt,
                quant=item.get("quantization") or "-",
                moe=_looks_moe(item.get("arch")),
                ctx_max=item.get("max_context_length"),
                ctx_loaded=item.get("loaded_context_length"),
                benchmarkable=model_type in ("llm", "vlm"),
                loaded=(item.get("state") == "loaded")
                or item.get("loaded_context_length") is not None,
                raw=item,
            )
        )
    return records


def lmstudio_enrich(records, v1_payload):
    """Best-effort backfill of size_bytes/params from GET /api/v1/models.

    The richer v1 listing (LM Studio 0.4.0+) may expose on-disk size and a
    parameter string that the v0 listing omits. Absent or malformed payloads
    leave records untouched -- never raises.
    """
    if not isinstance(v1_payload, dict):
        return
    # The native v1 listing nests under "models" and keys each entry by "key";
    # tolerate the OpenAI-style "data"/"id" shape too in case a version differs.
    items = v1_payload.get("models")
    if not isinstance(items, list):
        items = v1_payload.get("data")
    if not isinstance(items, list):
        return
    by_id = {}
    for item in items:
        if not isinstance(item, dict):
            continue
        ident = item.get("key") or item.get("id")
        if ident:
            by_id[ident] = item
    for rec in records:
        extra = by_id.get(rec.name)
        if not extra:
            continue
        size = extra.get("size_bytes")
        if isinstance(size, (int, float)) and size > 0:
            rec.size_bytes = size
        params = extra.get("params_string")
        if params:
            rec.params = params


def parse_lmstudio_bench(response):
    """Read server-measured throughput from an LM Studio completion response."""
    stats = (response or {}).get("stats")
    if not isinstance(stats, dict):
        return None
    # A degenerate run (model emits 1 token then EOS) makes LM Studio divide ~1
    # token by ~0s and report a nonsense rate (seen: 142857 tok/s). The streamed
    # paths already require >=2 tokens; reject it here too so a non-representative
    # number never reaches the cache.
    usage = (response or {}).get("usage")
    if isinstance(usage, dict):
        completed = usage.get("completion_tokens")
        if isinstance(completed, int) and completed < 2:
            return None
    tps = stats.get("tokens_per_second")
    if not isinstance(tps, (int, float)) or tps <= 0:
        return None
    ttft = stats.get("time_to_first_token")
    if not isinstance(ttft, (int, float)):
        ttft = None
    return BenchResult(float(tps), ttft, tps_source="lmstudio_stats",
                       observed_backend="lmstudio",
                       system_fingerprint=(response or {}).get("system_fingerprint"))


def parse_ollama_bench(response):
    """Compute throughput (and TTFT) from an Ollama /api/generate response."""
    response = response or {}
    eval_count = response.get("eval_count")
    eval_duration = response.get("eval_duration")
    if not isinstance(eval_count, (int, float)) or not isinstance(eval_duration, (int, float)):
        return None
    # Need >=2 generated tokens for a meaningful rate: a 1-token run (immediate
    # EOS) over a near-zero eval_duration yields a nonsense throughput (matches
    # the streamed paths' tokens<2 guard).
    if eval_count < 2 or eval_duration <= 0:
        return None
    tps = float(eval_count) / (float(eval_duration) / 1_000_000_000.0)
    # Time to first token = model load + prompt evaluation, in seconds.
    ttft = None
    load = response.get("load_duration") or 0
    prompt_eval = response.get("prompt_eval_duration")
    if isinstance(prompt_eval, (int, float)) and prompt_eval > 0:
        ttft = (float(load) + float(prompt_eval)) / 1_000_000_000.0
    return BenchResult(tps, ttft, tps_source="ollama", observed_backend="ollama")


# --- formatting helpers (ported from the original ollama-list-with-tps) ------


def parse_modified(value):
    if not value:
        return None
    cleaned = value.replace("Z", "+00:00")
    try:
        return datetime.fromisoformat(cleaned)
    except ValueError:
        return None


def human_age(value):
    dt = parse_modified(value)
    if dt is None:
        return value or "-"
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=timezone.utc)
    now = datetime.now(timezone.utc)
    seconds = max(0, int((now - dt.astimezone(timezone.utc)).total_seconds()))
    units = [
        ("year", 365 * 24 * 60 * 60),
        ("month", 30 * 24 * 60 * 60),
        ("week", 7 * 24 * 60 * 60),
        ("day", 24 * 60 * 60),
        ("hour", 60 * 60),
        ("minute", 60),
    ]
    for name, unit_seconds in units:
        count = seconds // unit_seconds
        if count:
            suffix = "" if count == 1 else "s"
            return f"{count} {name}{suffix} ago"
    return "just now"


def human_size(size):
    try:
        value = float(size)
    except (TypeError, ValueError):
        return "-"
    units = ["B", "KB", "MB", "GB", "TB"]
    for unit in units:
        if value < 1024 or unit == units[-1]:
            if unit == "B":
                return f"{int(value)} {unit}"
            return f"{value:.1f} {unit}"
        value /= 1024
    return "-"


def human_ctx(ctx):
    try:
        value = float(ctx)
    except (TypeError, ValueError):
        return "-"
    if value <= 0:
        return "-"
    k = value / 1024
    if k < 1024:
        return f"{k:.0f}k"
    return f"{k / 1024:.1f}".rstrip("0").rstrip(".") + "M"


def quant_bits_per_weight(quant):
    # Approximate stored bits per weight (payload + quant scales) for the
    # quantization levels Ollama reports. Used to sanity-check and, when
    # needed, estimate parameter counts from on-disk size.
    q = (quant or "").lower()
    if any(t in q for t in ("fp4", "mxfp4", "nvfp4", "nf4", "int4", "q4")):
        return 4.5
    if "q5" in q:
        return 5.5
    if "q6" in q:
        return 6.5
    if any(t in q for t in ("fp8", "int8", "q8")):
        return 8.5
    if any(t in q for t in ("bf16", "fp16", "f16")):
        return 16.0
    if any(t in q for t in ("fp32", "f32")):
        return 32.0
    return 8.0


def human_params(total, expert_count, expert_used):
    if not total:
        return "-"
    total_b = total / 1e9
    if expert_count and expert_used and expert_count > 1:
        return f"{total_b:.0f}B MoE {expert_used}/{expert_count}"
    return f"{total_b:.0f}B"


def effective_bpw(rec):
    """Effective bits per weight: on-disk bits / parameter count, else None.

    Exact when param_count is a real reported/parsed value; for size-estimated
    counts it merely recovers the assumed width (flagged via param_estimated).
    """
    size = rec.size_bytes
    count = rec.param_count
    if not size or not count or size <= 0 or count <= 0:
        return None
    return (float(size) * 8.0) / float(count)


def human_bpw(rec):
    bpw = effective_bpw(rec)
    if bpw is None:
        return "-"
    prefix = "~" if rec.param_estimated else ""
    return f"{prefix}{bpw:.2f}"


# --- Ollama provider parsing ------------------------------------------------


def model_format(model):
    details = model.get("details")
    if not isinstance(details, dict):
        return ""
    value = details.get("format")
    return value.lower() if isinstance(value, str) else ""


def is_moe(model, info):
    # gguf models expose an .expert_count in model_info; safetensors/MLX models
    # have a sparse model_info, so fall back to the family/architecture name.
    for key, value in info.items():
        if key.endswith(".expert_count"):
            try:
                if int(value) > 1:
                    return True
            except (TypeError, ValueError):
                pass
    arch = (info.get("general.architecture") or "").lower()
    details = model.get("details") or {}
    family = (details.get("family") or "").lower()
    families = " ".join(details.get("families") or []).lower()
    return _looks_moe(arch, family, families)


def ollama_param_count(model, info):
    """Resolve (total, estimated, expert_count, expert_used) for a model.

    Prefers general.parameter_count; discards it when the implied bits/weight
    far exceeds the quant's nominal width (some MLX/safetensors models ship a
    bogus count) and estimates from on-disk size instead. `estimated` is True
    only on that size-derived fallback.
    """
    total = None
    expert_count = None
    expert_used = None
    for key, value in info.items():
        if key == "general.parameter_count":
            total = value
        elif key.endswith(".expert_count"):
            expert_count = value
        elif key.endswith(".expert_used_count"):
            expert_used = value

    size = model.get("size")
    quant = (model.get("details") or {}).get("quantization_level")
    bpw = quant_bits_per_weight(quant)
    estimated = False

    # Some MLX/safetensors models ship a bogus general.parameter_count (e.g. a
    # 26B model that reports 6B). A real quant can't pack more bits per weight
    # than fp16, so an implied width far above the quant's nominal one means the
    # reported count is wrong -- discard it and estimate from the file size.
    if total and size and bpw:
        implied = (float(size) * 8.0) / float(total)
        if implied > bpw * 2.5:
            total = None
    if not total and size and bpw:
        total = int(float(size) * 8.0 / bpw)
        estimated = True

    return total, estimated, expert_count, expert_used


def ollama_params(model, info):
    total, estimated, expert_count, expert_used = ollama_param_count(model, info)
    text = human_params(total, expert_count, expert_used)
    if estimated and text != "-":
        text = "~" + text
    return text


def ollama_context_length(info):
    arch = info.get("general.architecture")
    if arch:
        value = info.get(f"{arch}.context_length")
        if isinstance(value, int):
            return value
    for key, value in info.items():
        if key.endswith(".context_length") and isinstance(value, int):
            return value
    return None


def ollama_parse_models(tags_models, info_map):
    """Build ModelRecords from /api/tags items + per-name /api/show model_info."""
    records = []
    for model in tags_models or []:
        name = model.get("name")
        if not name:
            continue
        info = (info_map or {}).get(name, {}) or {}
        fmt = model_format(model)
        details = model.get("details") or {}
        total, estimated, expert_count, expert_used = ollama_param_count(model, info)
        params_text = human_params(total, expert_count, expert_used)
        if estimated and params_text != "-":
            params_text = "~" + params_text
        records.append(
            ModelRecord(
                provider="ollama",
                name=name,
                fmt=fmt,
                params=params_text,
                param_count=total,
                param_estimated=estimated,
                moe=is_moe(model, info),
                quant=details.get("quantization_level") or "-",
                size_bytes=model.get("size"),
                modified_at=model.get("modified_at"),
                ctx_max=ollama_context_length(info),
                benchmarkable=fmt in ("gguf", "safetensors"),
                digest=model.get("digest"),
                raw=model,
            )
        )
    return records


def ollama_running_digests(ps_payload):
    """Extract (digests, names) of currently-loaded models from /api/ps.

    Ollama's /api/ps lists the models resident in memory; each entry carries the
    same `digest` and `name` that /api/tags does, so either identifies a loaded
    model. Digest is the robust key (immune to tag renames); name is the fallback.
    A missing or malformed payload yields empty sets -- callers then mark nothing.
    """
    models = (ps_payload or {}).get("models")
    if not isinstance(models, list):
        return set(), set()
    digests, names = set(), set()
    for item in models:
        if not isinstance(item, dict):
            continue
        if item.get("digest"):
            digests.add(item["digest"])
        if item.get("name"):
            names.add(item["name"])
    return digests, names


# --- mlx provider parsing (mlx_lm.server) ------------------------------------


def mlx_parse_models(payload):
    """Parse a GET /v1/models response from mlx_lm.server into ModelRecords.

    The listing carries only model ids; everything else comes from the local
    HF-cache enrichment (when running on the server's machine) or stays "-".
    """
    data = (payload or {}).get("data")
    if not isinstance(data, list):
        return []
    records = []
    for item in data:
        if not isinstance(item, dict):
            continue
        model_id = item.get("id")
        if not model_id:
            continue
        records.append(
            ModelRecord(
                provider="mlx",
                name=model_id,
                fmt="mlx",
                # Optimistic default: remote hosts can't check configs, and a
                # failed bench only warns. Local enrichment demotes non-LLMs.
                benchmarkable=True,
                raw=item,
            )
        )
    return records


def _mlx_snapshot(hub_root, model_id):
    """Locate a model's on-disk snapshot: HF-cache repo, or a path id directly.

    Returns (snapshot_dir, refs_main_path); the ref is None for path ids.
    mlx_lm.server appends its --model CLI arg as an absolute-path id when it
    points at a local directory.
    """
    path = Path(model_id)
    if path.is_absolute():
        return (path, None) if path.is_dir() else (None, None)
    repo = Path(hub_root) / ("models--" + model_id.replace("/", "--"))
    ref = repo / "refs" / "main"
    try:
        commit = ref.read_text(encoding="utf-8").strip()
    except OSError:
        return None, None
    snapshot = repo / "snapshots" / commit
    return (snapshot, ref) if snapshot.is_dir() else (None, None)


def _apply_safetensors_config(rec, config):
    """Backfill fmt/ctx/quant/MoE/params on rec from a parsed safetensors (MLX)
    config.json. Params are size-derived, so rec.size_bytes must already be set.
    Shared by the mlx provider and the unsloth provider's MLX fallback.
    """
    rec.fmt = "safetensors"
    ctx = config.get("max_position_embeddings")
    if isinstance(ctx, int) and ctx > 0:
        rec.ctx_max = ctx
    quant = config.get("quantization")
    bits = quant.get("bits") if isinstance(quant, dict) else None
    if isinstance(bits, (int, float)) and bits > 0:
        rec.quant = f"{bits:g}bit"
        bpw = float(bits) + 0.5    # payload + quant scales, as elsewhere
    else:
        bpw = 16.0                 # unquantized MLX models ship bf16
    rec.moe = any(
        isinstance(value, int) and value > 1 and "expert" in key
        for key, value in config.items()
    )
    if rec.size_bytes:
        total = int(float(rec.size_bytes) * 8.0 / bpw)
        rec.param_count = total
        rec.param_estimated = True   # always size-derived for MLX repos
        text = human_params(
            total, config.get("num_experts"), config.get("num_experts_per_tok"))
        if text != "-":
            text = "~" + text      # estimated from size, like Ollama's path
        rec.params = text


def mlx_enrich(records, hub_root):
    """Best-effort backfill of size/quant/ctx/MoE/params from the local HF cache.

    Only meaningful when toks runs on the same machine as mlx_lm.server (the
    default localhost setup). Absent repos or malformed configs leave records
    untouched -- never raises. A repo without a top-level config.json is not an
    mlx-lm text model (the server's loose cache scan also matches e.g.
    diffusers image repos), so those are demoted to non-benchmarkable.
    """
    for rec in records:
        snapshot, ref = _mlx_snapshot(hub_root, rec.name)
        if snapshot is None:
            continue
        try:
            size = sum(f.stat().st_size for f in snapshot.rglob("*") if f.is_file())
        except OSError:
            size = None
        if size:
            rec.size_bytes = size
        if ref is not None:
            try:
                mtime = ref.stat().st_mtime
                rec.modified_at = datetime.fromtimestamp(mtime, tz=timezone.utc).isoformat()
            except OSError:
                pass
        try:
            with (snapshot / "config.json").open("r", encoding="utf-8") as handle:
                config = json.load(handle)
        except (OSError, json.JSONDecodeError):
            config = None
        if not isinstance(config, dict) or not config.get("model_type"):
            rec.benchmarkable = False
            continue
        _apply_safetensors_config(rec, config)


def bench_from_sse(lines, start, clock=time.monotonic):
    """Time an OpenAI-style SSE completion stream client-side.

    mlx_lm.server reports no speed stats, so we measure: TTFT is the first
    content chunk minus `start` (request send), throughput is the tokens after
    the first over the first->last chunk interval -- cleanly excluding prompt
    eval. The token count comes from the final usage chunk (requested via
    stream_options include_usage), falling back to counting content chunks.
    Returns None when nothing measurable arrived.

    Even though we client-time, we still inspect each event for a llama.cpp
    `timings` block or a `b<build>-…` fingerprint: their presence means the port
    is actually a llama.cpp server, not mlx_lm -- the tell that catches an
    impostor squatting on the mlx default port.
    """
    first = last = None
    chunk_count = 0
    completion_tokens = None
    fingerprint = None
    timings_block = None
    for raw in lines:
        line = raw.decode("utf-8", "replace") if isinstance(raw, bytes) else raw
        line = line.strip()
        if not line.startswith("data:"):
            continue
        payload = line[len("data:"):].strip()
        if payload == "[DONE]":
            break
        try:
            event = json.loads(payload)
        except json.JSONDecodeError:
            continue
        if event.get("system_fingerprint"):
            fingerprint = event["system_fingerprint"]
        if isinstance(event.get("timings"), dict):
            timings_block = event["timings"]
        usage = event.get("usage")
        if isinstance(usage, dict):
            tokens = usage.get("completion_tokens")
            if isinstance(tokens, int) and tokens > 0:
                completion_tokens = tokens
        choices = event.get("choices") or []
        content = ""
        if choices and isinstance(choices[0], dict):
            content = (choices[0].get("text")
                       or (choices[0].get("delta") or {}).get("content") or "")
        if content:
            now = clock()
            if first is None:
                first = now
            last = now
            chunk_count += 1
    if first is None or last <= first:
        return None
    tokens = completion_tokens or chunk_count
    if tokens < 2:
        return None
    return BenchResult(
        (tokens - 1) / (last - first), first - start, tps_source="client_timed",
        observed_backend=_classify_streamed_backend(
            fingerprint, timings_block is not None, otherwise="mlx_lm"),
        system_fingerprint=fingerprint,
        **(_draft_stats(timings_block) if timings_block is not None else {}))


# --- Unsloth Studio provider parsing (llama.cpp server) ----------------------

# GGUF general.file_type enum -> quant label (ggml ftype values).
GGUF_FILE_TYPES = {
    0: "F32", 1: "F16", 2: "Q4_0", 3: "Q4_1", 7: "Q8_0", 8: "Q5_0",
    9: "Q5_1", 10: "Q2_K", 11: "Q3_K_S", 12: "Q3_K_M", 13: "Q3_K_L",
    14: "Q4_K_S", 15: "Q4_K_M", 16: "Q5_K_S", 17: "Q5_K_M", 18: "Q6_K",
    19: "IQ2_XXS", 20: "IQ2_XS", 21: "Q2_K_S", 22: "IQ3_XS", 23: "IQ3_XXS",
    24: "IQ1_S", 25: "IQ4_NL", 26: "IQ3_S", 27: "IQ3_M", 28: "IQ2_S",
    29: "IQ2_M", 30: "IQ4_XS", 31: "IQ1_M", 32: "BF16",
}

_GGUF_SIMPLE = {0: "<b", 1: "<B", 2: "<h", 3: "<H", 4: "<i", 5: "<I",
                6: "<f", 7: "<?", 10: "<q", 11: "<Q", 12: "<d"}


def _gguf_read_value(handle, vtype):
    fmt = _GGUF_SIMPLE.get(vtype)
    if fmt is not None:
        return struct.unpack(fmt, handle.read(struct.calcsize(fmt)))[0]
    if vtype == 8:                                   # string
        (length,) = struct.unpack("<Q", handle.read(8))
        return handle.read(length).decode("utf-8", "replace")
    if vtype == 9:                                   # array
        (elem_type,) = struct.unpack("<I", handle.read(4))
        (count,) = struct.unpack("<Q", handle.read(8))
        return [_gguf_read_value(handle, elem_type) for _ in range(count)]
    raise ValueError(f"unknown GGUF value type {vtype}")


def read_gguf_meta(path):
    """Parse a GGUF header for param count, quant, context length, and MoE flags.

    Sums tensor-info dimension products for an *exact* parameter count (tensor
    data itself is never read); reads general.file_type for the quant label and
    the architecture's context_length. Returns a dict, or None on any malformed
    or unreadable input -- callers treat enrichment as best-effort.
    """
    try:
        with open(path, "rb") as handle:
            if handle.read(4) != b"GGUF":
                return None
            (version,) = struct.unpack("<I", handle.read(4))
            if version < 2:
                return None
            (n_tensors,) = struct.unpack("<Q", handle.read(8))
            (n_kv,) = struct.unpack("<Q", handle.read(8))
            arch = None
            file_type = None
            expert_count = None
            expert_used = None
            ctx_by_key = {}
            for _ in range(n_kv):
                (klen,) = struct.unpack("<Q", handle.read(8))
                key = handle.read(klen).decode("utf-8", "replace")
                (vtype,) = struct.unpack("<I", handle.read(4))
                value = _gguf_read_value(handle, vtype)
                if key == "general.architecture":
                    arch = value
                elif key == "general.file_type":
                    file_type = value
                elif key.endswith(".expert_count"):
                    expert_count = value
                elif key.endswith(".expert_used_count"):
                    expert_used = value
                elif key.endswith(".context_length"):
                    ctx_by_key[key] = value
            total = 0
            for _ in range(n_tensors):
                (nlen,) = struct.unpack("<Q", handle.read(8))
                handle.read(nlen)                    # tensor name
                (ndims,) = struct.unpack("<I", handle.read(4))
                dims = struct.unpack(f"<{ndims}Q", handle.read(8 * ndims))
                handle.read(4)                       # ggml type
                handle.read(8)                       # data offset
                product = 1
                for dim in dims:
                    product *= dim
                total += product
    except (OSError, struct.error, ValueError, UnicodeDecodeError):
        return None
    if total <= 0:
        return None
    ctx = ctx_by_key.get(f"{arch}.context_length") if arch else None
    if ctx is None and ctx_by_key:
        ctx = next(iter(ctx_by_key.values()))
    quant = GGUF_FILE_TYPES.get(file_type)
    if quant is None and file_type is not None:
        quant = f"ftype{file_type}"
    return {
        "param_count": total,
        "file_type": file_type,
        "quant": quant,
        "ctx": ctx if isinstance(ctx, int) and ctx > 0 else None,
        "expert_count": expert_count,
        "expert_used": expert_used,
    }


def select_main_gguf(snapshot):
    """Pick the main weights GGUF in a snapshot, ignoring projector/draft files.

    A repo may ship the weights file plus extras (mmproj-* vision projectors, an
    mtp-* draft head); the largest *.gguf that is neither is the model itself.
    """
    candidates = []
    try:
        for path in snapshot.glob("*.gguf"):
            lowered = path.name.lower()
            if "mmproj" in lowered or "mtp" in lowered:
                continue
            try:
                candidates.append((path.stat().st_size, path))
            except OSError:
                continue
    except OSError:
        return None
    if not candidates:
        return None
    candidates.sort(reverse=True)
    return candidates[0][1]


# Best-effort backstop for the non-text models Studio's can_chat flag mislabels
# (embeddings report can_chat=True; speech models likewise). Matched as a
# case-insensitive substring of the repo id.
NON_TEXTGEN_HINTS = ("bge", "embed", "rerank", "tts", "stt", "whisper", "asr")


def unsloth_parse_local(payload):
    """Parse a GET /api/hub/local response from Unsloth Studio into ModelRecords.

    Studio's local inventory enumerates downloaded models across every source it
    sees (its HF cache, LM Studio, Ollama). We keep only the HF-cache,
    text-generation models: that is the shared store where Unsloth-served GGUF and
    MLX/safetensors weights live, so the listing is format-agnostic (a future
    `…-MLX-8bit` build appears automatically) without re-listing the very models
    toks' own lmstudio/ollama providers already report.

    Deliberately NOT namespace-scoped to `unsloth/*`: an `mlx-community/*` chat
    model in the HF cache is listed here too, so Studio's throughput for the exact
    same files can be compared against the `mlx` provider's number.

    Like mlx, only the id (an HF repo id) is taken here; size/quant/params/ctx are
    backfilled from the cached weights by unsloth_enrich. Text-gen classification
    is best-effort (Studio's flags are incomplete).
    """
    models = (payload or {}).get("models")
    if not isinstance(models, list):
        return []
    records = []
    for item in models:
        if not isinstance(item, dict):
            continue
        model_id = item.get("id")
        if not model_id or not _unsloth_is_listable(item):
            continue
        records.append(
            ModelRecord(
                provider="unsloth",
                name=model_id,
                benchmarkable=True,
                raw=item,
            )
        )
    return records


def _unsloth_is_listable(item):
    """True for a downloaded, HF-cache, text-generation model worth listing."""
    if item.get("source") != "hf_cache":
        return False                                  # other providers' territory
    if item.get("model_format") not in ("gguf", "safetensors"):
        return False                                  # unknown/partial junk
    if not (item.get("capabilities") or {}).get("can_chat"):
        return False                                  # image gen etc.
    lowered = str(item.get("id", "")).lower()
    return not any(hint in lowered for hint in NON_TEXTGEN_HINTS)


def _snapshot_modified_at(rec, ref):
    """Set rec.modified_at from the HF-cache ref's mtime (no-op for path ids)."""
    if ref is None:
        return
    try:
        mtime = ref.stat().st_mtime
        rec.modified_at = datetime.fromtimestamp(mtime, tz=timezone.utc).isoformat()
    except OSError:
        pass


def apply_gguf_meta(rec, gguf_path):
    """Backfill fmt/quant/ctx/MoE/exact-params and size from a model's main GGUF.

    Sets rec.size_bytes from the GGUF file and, when its header parses, fmt/quant/
    ctx_max/moe/param_count/param_estimated and the MoE-aware params string (exact,
    summed from the tensor table). Does NOT touch modified_at -- each caller sets
    that from its own source (HF ref mtime vs. the GGUF's own mtime). Returns True
    when the header parsed; False otherwise (size may still have been set).
    """
    try:
        rec.size_bytes = gguf_path.stat().st_size
    except OSError:
        pass
    meta = read_gguf_meta(gguf_path)
    if not meta:
        return False
    rec.fmt = "gguf"
    if meta["quant"]:
        rec.quant = meta["quant"]
    if meta["ctx"]:
        rec.ctx_max = meta["ctx"]
    expert_count = meta["expert_count"]
    rec.moe = bool(isinstance(expert_count, int) and expert_count > 1)
    rec.param_count = meta["param_count"]
    rec.param_estimated = False      # exact, summed from the tensor table
    rec.params = human_params(meta["param_count"], expert_count, meta["expert_used"])
    return True


def unsloth_enrich(records, hub_root):
    """Backfill size/quant/params/ctx/MoE from each model's cached weights.

    Reads the main GGUF header for an *exact* param count when one is present;
    otherwise falls back to the safetensors/MLX config.json (size-derived, like
    the mlx provider) so the MLX builds listed for cross-runtime comparison still
    show metadata. Meaningful only on the server's machine; absent repos or
    malformed files leave the record untouched -- never raises.
    """
    for rec in records:
        snapshot, ref = _mlx_snapshot(hub_root, rec.name)
        if snapshot is None:
            continue
        main = select_main_gguf(snapshot)
        if main is not None:
            _snapshot_modified_at(rec, ref)
            apply_gguf_meta(rec, main)
            continue
        # No GGUF -> an MLX/safetensors build (e.g. an mlx-community repo listed
        # for cross-runtime comparison): enrich from config.json, size-derived.
        try:
            with (snapshot / "config.json").open("r", encoding="utf-8") as handle:
                config = json.load(handle)
        except (OSError, json.JSONDecodeError):
            continue
        if not isinstance(config, dict) or not config.get("model_type"):
            continue
        try:
            rec.size_bytes = sum(
                f.stat().st_size for f in snapshot.rglob("*") if f.is_file())
        except OSError:
            pass
        _snapshot_modified_at(rec, ref)
        _apply_safetensors_config(rec, config)


# --- llama.cpp server provider parsing (llama-server /v1/models + /props) -----


def llama_parse_models(payload):
    """Parse a GET /v1/models response from llama-server into ModelRecords.

    llama-server returns both an Ollama-style `models` array and an OpenAI-style
    `data` array; we read `data`, whose `meta` block already carries an exact
    param count, on-disk size, and context lengths (so SIZE/PARAMS/BPW/CTX are
    populated even over a network). The quant the BPW/TAG column wants is *not*
    in `meta`; it comes from the GGUF, backfilled by llama_enrich when local.
    Format is always gguf -- llama-server serves GGUF only.
    """
    data = (payload or {}).get("data")
    if not isinstance(data, list):
        return []
    records = []
    for item in data:
        if not isinstance(item, dict):
            continue
        model_id = item.get("id")
        if not model_id:
            continue
        # llama-server runs one model per process and /v1/models names exactly it,
        # so every listed record is the resident (loaded) model.
        rec = ModelRecord(provider="llama", name=model_id, fmt="gguf",
                          benchmarkable=True, loaded=True, raw=item)
        meta = item.get("meta")
        if isinstance(meta, dict):
            n_params = meta.get("n_params")
            if isinstance(n_params, int) and n_params > 0:
                rec.param_count = n_params
                rec.param_estimated = False     # server-reported, exact
                rec.params = human_params(n_params, None, None)
            size = meta.get("size")
            if isinstance(size, (int, float)) and size > 0:
                rec.size_bytes = size
            n_ctx = meta.get("n_ctx")
            if isinstance(n_ctx, int) and n_ctx > 0:
                rec.ctx_loaded = n_ctx          # running context
            n_ctx_train = meta.get("n_ctx_train")
            if isinstance(n_ctx_train, int) and n_ctx_train > 0:
                rec.ctx_max = n_ctx_train       # trained max
        records.append(rec)
    return records


def llama_enrich(records, props):
    """Backfill quant/MoE/exact-params/ctx from the loaded model's GGUF.

    llama-server's /props names the on-disk GGUF (model_path); reading its header
    yields the quant the listing omits (the BPW/TAG source) plus exact params and
    the MoE flag. Targets the record whose name matches model_alias, or the sole
    record when there is one. Off-box the path won't exist, so this is a silent
    no-op; absent or malformed files leave the record untouched -- never raises.
    """
    if not isinstance(props, dict):
        return
    model_path = props.get("model_path")
    if not isinstance(model_path, str) or not model_path:
        return
    alias = props.get("model_alias")
    target = next((r for r in records if r.name == alias), None)
    if target is None and len(records) == 1:
        target = records[0]
    if target is None:
        return
    path = Path(model_path)
    if path.suffix.lower() != ".gguf" or not path.is_file():
        return
    if apply_gguf_meta(target, path):
        try:
            mtime = path.stat().st_mtime
            target.modified_at = datetime.fromtimestamp(
                mtime, tz=timezone.utc).isoformat()
        except OSError:
            pass


def _canonical_model_id(value):
    """Reduce a model id to a comparable `org/name` form, lower-cased.

    Studio's two endpoints name the *same* loaded model differently: the
    `llama-server` (`:11435`) echoes the clean repo id `org/name`, while Studio's
    own API (`:8888`) echoes the on-disk **HF-cache path**
    `.../models--org--name/snapshots/<sha>/<file>.gguf`. The cache dir encodes the
    repo id (`models--org--name` -> `org/name`), so we recover it from any path
    that contains such a segment; a plain id or bare alias passes through unchanged.
    """
    s = str(value or "").strip().lower().replace("\\", "/")
    if not s:
        return ""
    for part in s.split("/"):
        if part.startswith("models--"):
            return part[len("models--"):].replace("--", "/")
    return s


def served_model_matches(requested, served):
    """True when the model a llama.cpp server actually served is the requested one.

    llama.cpp (and Unsloth Studio on top of it) echo the *loaded* model's id in the
    response `model` field, not the requested name -- so a benchmark only measures
    the model we asked for when the two agree. Both sides are canonicalised to
    `org/name` (decoding HF-cache paths), then compared on the full id and on the
    bare alias (the part after the last '/') so a server that reports just
    `demo-GGUF` for a requested `org/demo-GGUF` still matches. An empty `served`
    means the server didn't tell us, so we can't verify and don't block.
    """
    req = _canonical_model_id(requested)
    srv = _canonical_model_id(served)
    if not req or not srv:
        return True
    if req == srv:
        return True
    return req.rsplit("/", 1)[-1] == srv.rsplit("/", 1)[-1]


def unsloth_served_ids(models_payload):
    """Canonical ids (+ bare aliases) of the model Studio reports as loaded.

    Studio's /v1/models echoes only the currently-loaded model; /api/hub/local
    lists every downloaded one. Canonicalising both sides to `org/name` (decoding
    HF-cache paths, see _canonical_model_id) lets a local record match the served
    id on the full id or the bare alias -- the same rule served_model_matches uses.
    Each id's bare alias is stored too, so an `org/name` <-> `name` split matches.
    Empty/malformed payload (or nothing loaded) yields an empty set: mark nothing.
    """
    data = (models_payload or {}).get("data")
    if not isinstance(data, list):
        return set()
    ids = set()
    for item in data:
        if not isinstance(item, dict):
            continue
        canon = _canonical_model_id(item.get("id"))
        if canon:
            ids.add(canon)
            ids.add(canon.rsplit("/", 1)[-1])
    return ids


def _opt_int(value):
    """An int as-is (0 preserved), else None -- keeps absent distinct from zero."""
    return value if isinstance(value, int) and not isinstance(value, bool) else None


def _draft_stats(timings):
    """Lift the speculative-decode + prefix-cache counters from a timings dict."""
    return {
        "draft_n": _opt_int(timings.get("draft_n")),
        "draft_n_accepted": _opt_int(timings.get("draft_n_accepted")),
        "cache_n": _opt_int(timings.get("cache_n")),
    }


def parse_llamacpp_timings(response):
    """Read server-measured throughput from a llama.cpp `timings` block.

    Unsloth Studio (a llama.cpp server) reports predicted_per_second and
    prompt_ms in the stream's final chunk -- accurate even over a network, so we
    prefer it to client-side timing. The same block carries the speculative-decode
    counters (draft_n / draft_n_accepted) and cache_n (prefix-cache hits), which we
    lift to explain the throughput. Returns None when absent or non-positive.
    """
    timings = (response or {}).get("timings")
    if not isinstance(timings, dict):
        return None
    tps = timings.get("predicted_per_second")
    if not isinstance(tps, (int, float)) or tps <= 0:
        return None
    ttft = None
    prompt_ms = timings.get("prompt_ms")
    if isinstance(prompt_ms, (int, float)) and prompt_ms > 0:
        ttft = float(prompt_ms) / 1000.0
    return BenchResult(float(tps), ttft, tps_source="llamacpp_timings",
                       observed_backend="llamacpp",
                       system_fingerprint=(response or {}).get("system_fingerprint"),
                       **_draft_stats(timings))


def bench_llamacpp_sse(lines, start, clock=time.monotonic, otherwise="unknown"):
    """Time a llama.cpp-server completion stream in a single live pass.

    Prefers the server's own llama.cpp `timings` (the first chunk to carry one);
    falls back to client-side timing (TTFT = first content chunk, throughput over
    the first->last interval) if a build ever omits timings. Returns None when
    nothing measurable arrived.

    Shared by the `unsloth` and `llama` providers. `otherwise` is the engine the
    fallback records when a stream carries neither timings nor a build fingerprint:
    multi-runtime Studio settles for 'unknown', a plain llama-server for 'llamacpp'
    (in practice unreachable -- llama.cpp always emits timings).
    """
    first = last = None
    chunk_count = 0
    completion_tokens = None
    server = None
    fingerprint = None
    for raw in lines:
        line = raw.decode("utf-8", "replace") if isinstance(raw, bytes) else raw
        line = line.strip()
        if not line.startswith("data:"):
            continue
        payload = line[len("data:"):].strip()
        if payload == "[DONE]":
            break
        try:
            event = json.loads(payload)
        except json.JSONDecodeError:
            continue
        if event.get("system_fingerprint"):
            fingerprint = event["system_fingerprint"]
        if server is None:
            server = parse_llamacpp_timings(event)
        usage = event.get("usage")
        if isinstance(usage, dict):
            tokens = usage.get("completion_tokens")
            if isinstance(tokens, int) and tokens > 0:
                completion_tokens = tokens
        choices = event.get("choices") or []
        content = ""
        if choices and isinstance(choices[0], dict):
            content = (choices[0].get("text")
                       or (choices[0].get("delta") or {}).get("content") or "")
        if content:
            now = clock()
            if first is None:
                first = now
            last = now
            chunk_count += 1
    if server is not None:
        return server
    if first is None or last <= first:
        return None
    tokens = completion_tokens or chunk_count
    if tokens < 2:
        return None
    # No llama.cpp timings: served via another runtime (transformers/mlx) or a
    # build that omits them; the caller's `otherwise` names the expected engine.
    return BenchResult(
        (tokens - 1) / (last - first), first - start, tps_source="client_timed",
        observed_backend=_classify_streamed_backend(fingerprint, False,
                                                     otherwise=otherwise),
        system_fingerprint=fingerprint)


# --- shared rendering -------------------------------------------------------


def tag_cell(rec):
    """Render the TAG badge from a record's format + MoE flag."""
    if rec.fmt == "safetensors":
        tag = "mlx"
    elif rec.fmt in ("gguf", "mlx"):
        tag = rec.fmt
    else:
        tag = ""
    if rec.moe:
        tag = (tag + " moe").strip()
    return tag or "-"


# --- benchmark cache --------------------------------------------------------

_PROVIDER_PREFIXES = ("ollama:", "lmstudio:", "mlx:", "unsloth:", "llama:")


def cache_key(rec):
    """Stable per-record cache key: provider:digest-or-name.

    The digest (Ollama) or model id (LM Studio) already identifies the exact
    model variant, so quantization is not part of the key -- this also lets
    legacy digest-keyed entries migrate cleanly (they store no quant).
    """
    inner = rec.digest or rec.name
    return f"{rec.provider}:{inner}"


def migrate_cache(cache):
    """Re-key legacy (pre-multi-provider) entries under the ollama: namespace.

    Legacy keys are bare digests or model names with no provider prefix. Any
    key already starting with a known provider prefix is left untouched, so the
    migration is idempotent.
    """
    if not isinstance(cache, dict):
        return {}
    migrated = {}
    for key, entry in cache.items():
        if isinstance(key, str) and key.startswith(_PROVIDER_PREFIXES):
            migrated[key] = entry
            continue
        if isinstance(entry, dict):
            entry = dict(entry)
            entry.setdefault("provider", "ollama")
        migrated[f"ollama:{key}"] = entry
    return migrated


def _cache_entry(cache, rec):
    entry = cache.get(cache_key(rec))
    return entry if isinstance(entry, dict) else None


def cached_tps(cache, rec):
    entry = _cache_entry(cache, rec)
    if not entry:
        return None
    value = entry.get("tokens_per_second")
    if isinstance(value, (int, float)) and value > 0:
        return float(value)
    return None


def cached_ttft(cache, rec):
    entry = _cache_entry(cache, rec)
    if not entry:
        return None
    value = entry.get("time_to_first_token")
    if isinstance(value, (int, float)) and value > 0:
        return float(value)
    return None


def _acceptance(entry):
    """Pooled speculative-decode acceptance for a cache entry, or None.

    Returns draft_n_accepted / draft_n when both are present and draft_n > 0; a
    non-speculating backend (no draft counters) yields None, rendered as '-'.
    """
    if not isinstance(entry, dict):
        return None
    drafted = entry.get("draft_n")
    accepted = entry.get("draft_n_accepted")
    if isinstance(drafted, int) and drafted > 0 and isinstance(accepted, (int, float)):
        return accepted / drafted
    return None


def cached_acceptance(cache, rec):
    return _acceptance(_cache_entry(cache, rec))


def _cached_by_kind(cache, rec, kind):
    """The nested per-kind aggregate (--bench-suite) for a record, or None."""
    entry = _cache_entry(cache, rec)
    bucket = entry.get("by_kind") if isinstance(entry, dict) else None
    sub = bucket.get(kind) if isinstance(bucket, dict) else None
    return sub if isinstance(sub, dict) else None


def cached_kind_tps(cache, rec, kind):
    sub = _cached_by_kind(cache, rec, kind)
    if sub:
        value = sub.get("tokens_per_second")
        if isinstance(value, (int, float)) and value > 0:
            return float(value)
    return None


def cached_kind_acceptance(cache, rec, kind):
    return _acceptance(_cached_by_kind(cache, rec, kind))


def tps_sort_key(cache, rec):
    tps = cached_tps(cache, rec)
    if tps is None:
        return (1, 0.0, rec.name or "")
    return (0, -tps, rec.name or "")


# --- table rendering --------------------------------------------------------

HEADER = ["PROVIDER", "NAME", "SIZE", "TAG", "PARAMS", "BPW", "CTX", "TTFT",
          "TOKENS/S", "ACC%", "MODIFIED"]
RIGHT_ALIGN = {"SIZE", "PARAMS", "BPW", "CTX", "TTFT", "TOKENS/S", "ACC%",
               "CODE/S", "CODE%"}


def _pct(value):
    return f"{value * 100:.0f}%" if value is not None else "-"


def _name_cell(rec, color):
    """NAME cell with a 2-column loaded marker: green '✓ ' when resident, else '  '.

    The marker width is always 2 visible columns (the ✓ or a plain space, plus a
    separating space) so names stay aligned whether or not a row is loaded.
    """
    mark = _color("✓", STATUS_OK, color) if rec.loaded else " "
    return f"{mark} {rec.name or '-'}"


def build_rows(records, cache, color=False):
    # The code-spread columns only earn their width when a displayed model carries
    # a --bench-suite result; otherwise they are omitted entirely (no empty churn).
    show_code = any(_cached_by_kind(cache, rec, "code") for rec in records)
    header = list(HEADER)
    if show_code:
        pos = header.index("ACC%") + 1
        header[pos:pos] = ["CODE/S", "CODE%"]
    rows = [header]
    for rec in records:
        tps = cached_tps(cache, rec)
        ttft = cached_ttft(cache, rec)
        acc = cached_acceptance(cache, rec)
        ctx = rec.ctx_loaded or rec.ctx_max
        row = [
            rec.provider,
            _name_cell(rec, color),
            human_size(rec.size_bytes),
            tag_cell(rec),
            rec.params or "-",
            human_bpw(rec),
            human_ctx(ctx),
            f"{ttft:.2f}" if ttft else "-",
            f"{tps:.1f}" if tps else "-",
            _pct(acc),
        ]
        if show_code:
            code_tps = cached_kind_tps(cache, rec, "code")
            row.append(f"{code_tps:.1f}" if code_tps else "-")
            row.append(_pct(cached_kind_acceptance(cache, rec, "code")))
        row.append(human_age(rec.modified_at) if rec.modified_at else "-")
        rows.append(row)
    return rows


# Softer than the default ANSI red/green so the status line reads as an accent,
# not an alarm: a spring green and a muted indianred from the 256-colour palette.
STATUS_OK = "38;5;78"
STATUS_BAD = "38;5;167"


def _color(text, code, enabled):
    return f"\x1b[{code}m{text}\x1b[0m" if enabled else text


def provider_status_line(statuses, color=True):
    """One-line summary of which providers answered the listing request.

    Each entry is `name ✓` (reachable) or `name ✗` (unreachable); the mark is
    coloured when `color` is set.
    """
    parts = []
    for name, ok in statuses:
        mark = _color("✓", STATUS_OK, color) if ok else _color("✗", STATUS_BAD, color)
        parts.append(f"{name} {mark}")
    return "  ".join(parts)


_ANSI_RE = re.compile(r"\x1b\[[0-9;]*m")


def _visible_width(cell):
    """Displayed width of a cell, ignoring ANSI colour escapes."""
    return len(_ANSI_RE.sub("", cell))


def _pad(cell, width, right):
    """Pad to `width` visible columns (str.ljust/rjust would miscount ANSI)."""
    fill = " " * max(0, width - _visible_width(cell))
    return fill + cell if right else cell + fill


def table(rows):
    col_count = len(rows[0]) if rows else 0
    widths = [0] * col_count
    for row in rows:
        for index, cell in enumerate(row):
            widths[index] = max(widths[index], _visible_width(cell))
    header = rows[0] if rows else []
    lines = []
    for r_index, row in enumerate(rows):
        cells = []
        for index, cell in enumerate(row):
            cells.append(_pad(cell, widths[index], header[index] in RIGHT_ALIGN))
        lines.append(" │ ".join(cells))
        if r_index == 0 and len(rows) > 1:
            lines.append("─┼─".join("─" * widths[index] for index in range(col_count)))
    return "\n".join(lines)


